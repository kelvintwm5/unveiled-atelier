# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# OAuth Client ID — NOT a secret, safe to store here.
# Create one at: Google Cloud Console → APIs & Services → Credentials
#   → Create Credentials → OAuth 2.0 Client ID → Web application
#   → Add http://localhost:5173 as an Authorized JavaScript Origin
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Your Google Sheet ID — the long string from the sheet URL.
# This is not sensitive (just an identifier), but keeping it in .env
# means you can change sheets without touching source code.
VITE_REAL_SHEET_ID=1y0BBDBkslFl5nMPXhchFMgtis9OpuOkToI9AAqrW9wc
